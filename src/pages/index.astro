---
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Global Founders</title>
  </head>

  <body class="bg-black text-white font-sans">

    <!-- Navbar -->
    <nav class="flex justify-between items-center px-10 py-6 border-b border-zinc-800">

      <h1 class="text-2xl font-bold">
        Global Founders
      </h1>

      <div class="flex gap-6 text-sm text-gray-300">
        <a href="#">Home</a>
        <a href="#">Articles</a>
        <a href="#">Interviews</a>
        <a href="#">About</a>
      </div>

    </nav>

    <!-- Hero -->
    <section class="text-center py-32 px-6">

      <h2 class="text-6xl font-bold leading-tight mb-6">
        Stories of Modern Business Leaders
      </h2>

      <p class="text-gray-400 text-lg max-w-2xl mx-auto">
        Discover startups, entrepreneurs, innovation,
        and the future of business.
      </p>

    </section>

    <!-- Cards -->
    <section class="grid md:grid-cols-3 gap-8 px-10 pb-24">

      <div class="bg-zinc-900 p-8 rounded-3xl">
        <h3 class="text-2xl font-semibold mb-4">
          Startup Growth
        </h3>

        <p class="text-gray-400">
          Learn how fast-growing startups scale globally.
        </p>
      </div>

      <div class="bg-zinc-900 p-8 rounded-3xl">
        <h3 class="text-2xl font-semibold mb-4">
          CEO Interviews
        </h3>

        <p class="text-gray-400">
          Insights from founders and industry leaders.
        </p>
      </div>

      <div class="bg-zinc-900 p-8 rounded-3xl">
        <h3 class="text-2xl font-semibold mb-4">
          AI & Innovation
        </h3>

        <p class="text-gray-400">
          Explore how AI is transforming industries.
        </p>
      </div>

    </section>

  </body>
</html>