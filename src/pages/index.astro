---
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Global Founders</title>
  </head>

  <body class="bg-black text-white font-sans">

    <!-- Navbar -->
    <nav class="flex justify-between items-center px-10 py-6 border-b border-zinc-800">

      <h1 class="text-3xl font-bold">
        Global Founders
      </h1>

      <div class="flex gap-8 text-gray-300">
        <a href="#">Home</a>
        <a href="#">Founders</a>
        <a href="#">Articles</a>
        <a href="#">AI</a>
        <a href="#">Contact</a>
      </div>

    </nav>

    <!-- Hero Section -->

    <section class="text-center py-32 px-6">

      <p class="text-zinc-400 uppercase tracking-[6px] mb-6">
        Future of Business & Innovation
      </p>

      <h1 class="text-7xl font-bold leading-tight max-w-5xl mx-auto">
        Stories Behind The World’s Greatest Founders
      </h1>

      <p class="text-zinc-400 text-xl mt-8 max-w-2xl mx-auto">
        Discover entrepreneurs, startups, AI innovation, and the minds shaping tomorrow.
      </p>

      <div class="flex justify-center gap-6 mt-12">

        <button class="bg-white text-black px-8 py-4 rounded-full font-semibold hover:scale-105 transition">
          Explore Founders
        </button>

        <button class="border border-zinc-700 px-8 py-4 rounded-full hover:bg-zinc-900 transition">
          Read Articles
        </button>

      </div>

    </section>

    <!-- Feature Cards -->

    <section class="grid md:grid-cols-3 gap-8 px-10 pb-24">

      <div class="bg-zinc-900 p-8 rounded-3xl hover:-translate-y-2 transition">

        <p class="text-zinc-500 mb-4">
          FEATURED
        </p>

        <h2 class="text-3xl font-bold mb-4">
          Startup Growth
        </h2>

        <p class="text-zinc-400">
          Learn how modern startups scale globally using technology and AI.
        </p>

      </div>

      <div class="bg-zinc-900 p-8 rounded-3xl hover:-translate-y-2 transition">

        <p class="text-zinc-500 mb-4">
          INTERVIEWS
        </p>

        <h2 class="text-3xl font-bold mb-4">
          CEO Interviews
        </h2>

        <p class="text-zinc-400">
          Insights from founders, executives, and industry leaders.
        </p>

      </div>

      <div class="bg-zinc-900 p-8 rounded-3xl hover:-translate-y-2 transition">

        <p class="text-zinc-500 mb-4">
          AI & TECH
        </p>

        <h2 class="text-3xl font-bold mb-4">
          AI Revolution
        </h2>

        <p class="text-zinc-400">
          Explore how artificial intelligence is transforming industries worldwide.
        </p>

      </div>

    </section>

    <!-- Featured Founders -->

    <section class="px-10 pb-28">

      <div class="flex justify-between items-center mb-10">

        <h2 class="text-5xl font-bold">
          Featured Founders
        </h2>

        <p class="text-zinc-500">
          Visionaries changing the future
        </p>

      </div>

      <div class="grid md:grid-cols-3 gap-8">

        <!-- Elon -->

        <div class="bg-zinc-900 rounded-3xl overflow-hidden hover:scale-[1.02] transition">

          <img
            src="https://images.unsplash.com/photo-1560250097-0b93528c311a?q=80&w=1200"
            class="w-full h-72 object-cover"
          />

          <div class="p-6">

            <h3 class="text-3xl font-bold mb-2">
              Elon Musk
            </h3>

            <p class="text-zinc-400">
              CEO of Tesla & SpaceX
            </p>

          </div>

        </div>

        <!-- Sam Altman -->

        <div class="bg-zinc-900 rounded-3xl overflow-hidden hover:scale-[1.02] transition">

          <img
            src="https://images.unsplash.com/photo-1500648767791-00dcc994a43e?q=80&w=1200"
            class="w-full h-72 object-cover"
          />

          <div class="p-6">

            <h3 class="text-3xl font-bold mb-2">
              Sam Altman
            </h3>

            <p class="text-zinc-400">
              CEO of OpenAI
            </p>

          </div>

        </div>

        <!-- Sundar -->

        <div class="bg-zinc-900 rounded-3xl overflow-hidden hover:scale-[1.02] transition">

          <img
            src="https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?q=80&w=1200"
            class="w-full h-72 object-cover"
          />

          <div class="p-6">

            <h3 class="text-3xl font-bold mb-2">
              Sundar Pichai
            </h3>

            <p class="text-zinc-400">
              CEO of Google
            </p>

          </div>

        </div>

      </div>

    </section>

  </body>

</html>