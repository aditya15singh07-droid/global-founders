---
import Layout from "../layouts/Layout.astro";
---

<Layout>

<section class="min-h-screen bg-black text-white">

  <!-- Navbar -->
  <nav class="flex justify-between items-center px-10 py-6 border-b border-zinc-800">

    <h1 class="text-3xl font-bold">
      Global Founders
    </h1>

    <div class="flex gap-8 text-zinc-300">
      <a href="#">Home</a>
      <a href="#">Articles</a>
      <a href="#">Interviews</a>
      <a href="#">About</a>
    </div>

  </nav>

  <!-- Hero -->
  <section class="text-center py-32 px-6">

    <p class="uppercase tracking-[0.3em] text-zinc-500 mb-6">
      Future of Business & Innovation
    </p>

    <h1 class="text-7xl font-bold max-w-5xl mx-auto leading-tight">
      Stories Behind The World’s Greatest Founders
    </h1>

    <p class="text-zinc-400 text-xl mt-8 max-w-3xl mx-auto">
      Discover entrepreneurs, startups, AI innovation,
      and the minds shaping tomorrow.
    </p>

    <div class="flex justify-center gap-6 mt-12">

      <button class="bg-white text-black px-8 py-4 rounded-full font-semibold hover:scale-105 transition">
        Explore Founders
      </button>

      <button class="border border-zinc-700 px-8 py-4 rounded-full hover:bg-zinc-900 transition">
        Read Articles
      </button>

    </div>

  </section>

  <!-- Cards -->
  <section class="grid md:grid-cols-3 gap-8 px-10 pb-28">

    <div class="bg-zinc-900 rounded-3xl p-8 hover:-translate-y-2 transition">
      <p class="text-zinc-500 mb-4">FEATURED</p>

      <h2 class="text-4xl font-bold mb-6">
        Startup Growth
      </h2>

      <p class="text-zinc-400 leading-8">
        Learn how modern startups scale globally using technology and AI.
      </p>
    </div>

    <div class="bg-zinc-900 rounded-3xl p-8 hover:-translate-y-2 transition">
      <p class="text-zinc-500 mb-4">INTERVIEWS</p>

      <h2 class="text-4xl font-bold mb-6">
        CEO Interviews
      </h2>

      <p class="text-zinc-400 leading-8">
        Insights from founders, executives, and industry leaders.
      </p>
    </div>

    <div class="bg-zinc-900 rounded-3xl p-8 hover:-translate-y-2 transition">
      <p class="text-zinc-500 mb-4">AI & TECH</p>

      <h2 class="text-4xl font-bold mb-6">
        AI Revolution
      </h2>

      <p class="text-zinc-400 leading-8">
        Explore how artificial intelligence is transforming industries worldwide.
      </p>
    </div>

  </section>

</section>
<section class="px-10 py-24">

  <div class="mb-16">
    <p class="uppercase tracking-[0.3em] text-zinc-500 text-sm">
      Featured Founders
    </p>

    <h2 class="text-5xl font-bold mt-4">
      Visionaries Changing The Future
    </h2>
  </div>

  <div class="grid md:grid-cols-3 gap-8">

    <div class="bg-zinc-900 rounded-3xl overflow-hidden hover:-translate-y-2 transition duration-300">
      <img
        src="https://images.unsplash.com/photo-1560250097-0b93528c311a"
        class="w-full h-80 object-cover"
      />

      <div class="p-6">
        <h3 class="text-3xl font-bold mb-2">
          Sundar Pichai
        </h3>

        <p class="text-zinc-400">
          CEO of Google
        </p>
      </div>
    </div>

    <div class="bg-zinc-900 rounded-3xl overflow-hidden hover:-translate-y-2 transition duration-300">
      <img
        src="https://images.unsplash.com/photo-1500648767791-00dcc994a43e"
        class="w-full h-80 object-cover"
      />

      <div class="p-6">
        <h3 class="text-3xl font-bold mb-2">
          Elon Musk
        </h3>

        <p class="text-zinc-400">
          Founder of Tesla & SpaceX
        </p>
      </div>
    </div>

    <div class="bg-zinc-900 rounded-3xl overflow-hidden hover:-translate-y-2 transition duration-300">
      <img
        src="https://images.unsplash.com/photo-1506794778202-cad84cf45f1d"
        class="w-full h-80 object-cover"
      />

      <div class="p-6">
        <h3 class="text-3xl font-bold mb-2">
          Satya Nadella
        </h3>

        <p class="text-zinc-400">
          CEO of Microsoft
        </p>
      </div>
    </div>

  </div>

</section>
</Layout>